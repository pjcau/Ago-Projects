# Development Dockerfile for React application with hot-reload support
FROM node:18-alpine

# Set working directory
WORKDIR /app

# Install dependencies (separate step for better layer caching)
COPY package*.json ./
RUN npm install

# Copy the rest of the application code
# Note: node_modules is excluded via .dockerignore when using volume mounting
COPY . .

# Expose port 3000 (default for react-scripts start)
EXPOSE 3000

# Set environment variables for development
ENV NODE_ENV=development
ENV CHOKIDAR_USEPOLLING=true
ENV FAST_REFRESH=true

# Start development server with hot-reload
CMD ["npm", "start"]
