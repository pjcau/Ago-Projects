{
  "name": "product-catalog-app",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "^5.0.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "docker:build": "docker build -t product-catalog-app:dev -f Dockerfile.dev .",
    "docker:build:prod": "docker build -t product-catalog-app:prod -f Dockerfile .",
    "docker:build:api": "docker build -t product-catalog-api:latest -f backend/Dockerfile backend/",
    "docker:dev": "pnpm docker:build && docker run -it --rm -p 3000:3000 -v $(pwd):/app -v /app/node_modules -e NODE_ENV=development -e REACT_APP_API_URL=http://localhost:8000 --name product-catalog-dev product-catalog-app:dev",
    "docker:api": "pnpm docker:build:api && docker run -it --rm -p 8000:8000 --name product-catalog-api product-catalog-api:latest",
    "docker:dev:compose": "docker-compose -f ../../docker-compose.yml up dev",
    "docker:dev:compose:build": "docker-compose -f ../../docker-compose.yml up --build dev",
    "docker:prod": "pnpm docker:build:prod && docker run -it --rm -p 3000:80 -e NODE_ENV=production --name product-catalog-prod product-catalog-app:prod",
    "docker:prod:compose": "docker-compose -f ../../docker-compose.yml up web",
    "docker:down": "docker-compose -f ../../docker-compose.yml down",
    "docker:clean": "docker system prune -f && docker volume prune -f",
    "docker:logs": "docker-compose -f ../../docker-compose.yml logs -f",
    "docker:restart": "docker-compose -f ../../docker-compose.yml restart dev"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}